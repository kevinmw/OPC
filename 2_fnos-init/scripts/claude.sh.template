#!/bin/bash
set -euo pipefail

# ═══════════════════════════════════════════════════
#   用户配置区域 — 请修改以下三个变量
# ═══════════════════════════════════════════════════

ANTHROPIC_AUTH_TOKEN=""           # API Key，例如 "sk-xxx"
ANTHROPIC_BASE_URL=""             # API 地址，例如 "http://192.168.100.1:1234"
ANTHROPIC_MODEL=""                # 模型名称，例如 "Qwen3.5"

# ═══════════════════════════════════════════════════

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# 检查变量是否都已配置
missing=0
if [[ -z "${ANTHROPIC_AUTH_TOKEN}" ]]; then
    echo -e "${RED}[错误] ANTHROPIC_AUTH_TOKEN 未配置${NC}"
    missing=1
fi
if [[ -z "${ANTHROPIC_BASE_URL}" ]]; then
    echo -e "${RED}[错误] ANTHROPIC_BASE_URL 未配置${NC}"
    missing=1
fi
if [[ -z "${ANTHROPIC_MODEL}" ]]; then
    echo -e "${RED}[错误] ANTHROPIC_MODEL 未配置${NC}"
    missing=1
fi

if [[ ${missing} -eq 1 ]]; then
    echo ""
    echo -e "${YELLOW}请用编辑器打开此脚本，填写上方三个变量后重新运行：${NC}"
    echo ""
    echo "  nano $(realpath "$0")"
    echo ""
    echo -e "${YELLOW}示例配置：${NC}"
    echo "  ANTHROPIC_AUTH_TOKEN=\"sk-abc123\""
    echo "  ANTHROPIC_BASE_URL=\"http://192.168.100.207:1234\""
    echo "  ANTHROPIC_MODEL=\"Qwen3-4B\""
    exit 1
fi

# 配置环境变量，所有模型统一使用同一个
export ANTHROPIC_AUTH_TOKEN
export ANTHROPIC_BASE_URL
export ANTHROPIC_MODEL
export ANTHROPIC_SMALL_FAST_MODEL="${ANTHROPIC_MODEL}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_MODEL}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_MODEL}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_MODEL}"

echo -e "${GREEN}[启动] API: ${ANTHROPIC_BASE_URL}${NC}"
echo -e "${GREEN}[启动] 模型: ${ANTHROPIC_MODEL}${NC}"
echo ""

claude --enable-auto-mode
